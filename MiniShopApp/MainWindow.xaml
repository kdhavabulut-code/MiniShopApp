<Window x:Class="MiniShopApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MiniShopApp.Models"
        Title="Mini Shop"
        Height="500"
        Width="950">


    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>
        
        
        

        <!-- LEFT SIDE: CATEGORIES + PRODUCTS -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" />
                <RowDefinition Height="3*" />
            </Grid.RowDefinitions>

            <!-- CATEGORIES -->



            <GroupBox Header="Categories" Grid.Row="0" Margin="5">
                <TreeView x:Name="CategoryTree"
              SelectedItemChanged="CategoryTree_SelectedItemChanged"/>
            </GroupBox>


            <!-- PRODUCTS -->
            <GroupBox Header="Products" Grid.Row="1" Margin="5">
                <StackPanel>


                    <ListBox x:Name="ProductList" Height="200">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <TextBlock Text="{Binding Name}" Width="200"/>

                                    <Button Content="Add"
                        Width="60"
                        Margin="10,0,0,0"
                        Click="AddProductButton_Click"
                        Tag="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>



                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- RIGHT SIDE: CART -->
        <GroupBox Header="Cart" Grid.Column="1" Margin="5">
            <StackPanel>
                <ListBox x:Name="CartList" Height="300">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Product.Name}" Width="140"/>
                                <TextBlock Text="{Binding Quantity, StringFormat={}{0}x }" Width="40"/>
                                <TextBlock Text="{Binding Product.Price}" Width="60"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Content="Remove Selected"
                        Height="30"
                        Margin="0,10,0,0"
                        Click="RemoveSelected_Click"/>

                <TextBlock x:Name="TotalText"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>